{
  "project": "TrainerPro",
  "url": "https://trainer-pro-phi.vercel.app",
  "command": "node screenshots-prod.mjs",
  "screenshots_dir": "screenshots",
  "pages": [
    { "file": "01-landing.png",    "label": "Landing",      "auth": false },
    { "file": "02-login.png",      "label": "Login",        "auth": false },
    { "file": "03-register.png",   "label": "Register",     "auth": false },
    { "file": "04-dashboard.png",  "label": "Dashboard",    "auth": true  },
    { "file": "05-clienti.png",    "label": "Clienti",      "auth": true  },
    { "file": "06-fasi.png",       "label": "Fasi",         "auth": true  },
    { "file": "07-diete.png",      "label": "Diete",        "auth": true  },
    { "file": "08-intake.png",     "label": "Intake",       "auth": true  }
  ],
  "checklists": {
    "Landing": [
      "TrainerPro logo and headline visible",
      "CTA buttons (Inizia gratis / Accedi) present",
      "3D dumbbell or hero graphic visible",
      "Features section rendered with icons",
      "Pricing tiers (Free / Personal Coach / Fitness Master) visible",
      "Dark background with orange accent color",
      "No broken layout or overflow"
    ],
    "Login": [
      "TrainerPro logo visible",
      "Email and password input fields present",
      "Accedi button visible",
      "Links to register and forgot-password present",
      "Dark glass card style applied"
    ],
    "Register": [
      "Name, email, password fields present",
      "Crea account gratuito button visible",
      "Link back to login present"
    ],
    "Dashboard": [
      "Sidebar with Dashboard, Clienti, Form Intake, Fasi, Diete nav items",
      "Welcome message with trainer name",
      "Stats cards (Clienti totali, Clienti attivi, Schede create, Piani alimentari) rendered",
      "Quick actions section visible",
      "Orange accent color applied throughout",
      "NO Misurazioni, Preventivi, or Export nav items"
    ],
    "Clienti": [
      "Page header with Clienti title",
      "Search and filter controls visible",
      "Nuovo cliente button present (top right)",
      "Empty state or client cards shown"
    ],
    "Fasi": [
      "Fasi & Piani title visible",
      "Stats cards rendered",
      "Filter controls present",
      "Empty state or phase list shown"
    ],
    "Diete": [
      "Piani Alimentari title visible",
      "Stats cards rendered",
      "Empty state or diet cards shown"
    ],
    "Intake": [
      "Form Intake title visible",
      "Link generation or form list present",
      "Dark styled layout"
    ]
  }
}
